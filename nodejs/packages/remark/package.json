{
  "name": "@illusions-lab/mdi-remark",
  "version": "2.0.5",
  "description": "remark plugin for MDI 2.0 (illusion Markdown): GFM + front matter + MDI extensions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illusions-lab/MDI.git",
    "directory": "nodejs/packages/remark"
  },
  "homepage": "https://mdi.illusions.app/",
  "bugs": "https://github.com/illusions-lab/MDI/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@illusions-lab/mdi": "workspace:*",
    "@types/mdast": "^4.0.0",
    "mdast-util-mdi": "workspace:*",
    "micromark-extension-mdi": "workspace:*",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "remark-stringify": "^11.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
