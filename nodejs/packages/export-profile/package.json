{
  "name": "@illusions-lab/mdi-export-profile",
  "version": "2.0.0",
  "description": "Shared export profile schema for MDI converters",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illusions-lab/MDI.git",
    "directory": "nodejs/packages/export-profile"
  },
  "homepage": "https://mdi.illusions.app/bindings/javascript/",
  "bugs": "https://github.com/illusions-lab/MDI/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
