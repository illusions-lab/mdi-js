{
  "name": "mdast-util-mdi",
  "version": "2.0.16",
  "description": "mdast serialization extension for Rust-owned MDI 2.0 nodes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illusions-lab/MDI.git",
    "directory": "nodejs/packages/mdast-util-mdi"
  },
  "homepage": "https://mdi.illusions.app/bindings/javascript/",
  "bugs": "https://github.com/illusions-lab/MDI/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.0",
    "@types/mdast": "^4.0.0",
    "@types/unist": "^3.0.0"
  },
  "devDependencies": {
    "@illusions-lab/mdi-core": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
