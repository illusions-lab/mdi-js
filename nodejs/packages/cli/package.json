{
  "name": "@illusions-lab/mdi-cli",
  "version": "2.0.18",
  "description": "Command-line interface for converting MDI (.mdi) documents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illusions-lab/MDI.git",
    "directory": "nodejs/packages/cli"
  },
  "homepage": "https://mdi.illusions.app/",
  "bugs": "https://github.com/illusions-lab/MDI/issues",
  "type": "module",
  "bin": {
    "mdi": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@illusions-lab/mdi": "workspace:*",
    "@illusions-lab/mdi-export-profile": "workspace:*",
    "@illusions-lab/mdi-to-pdf": "workspace:*",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.0.0",
    "jszip": "^3.10.1"
  }
}
