{
  "name": "@illusions-lab/mdi-to-pdf",
  "version": "2.0.4",
  "description": "Render MDI (.mdi) documents to PDF",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illusions-lab/mdi-js.git",
    "directory": "packages/to-pdf"
  },
  "homepage": "https://illusions-lab.github.io/mdi-js/",
  "bugs": "https://github.com/illusions-lab/mdi-js/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@illusions-lab/mdi-to-html": "workspace:*",
    "playwright": "^1.48.0",
    "@types/mdast": "^4.0.0"
  },
  "devDependencies": {
    "@illusions-lab/mdi-remark": "workspace:*",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.0.0"
  }
}
