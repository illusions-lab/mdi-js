{
  "name": "@mdi/cli",
  "version": "0.0.0",
  "description": "Command-line interface for converting MDI (.mdi) documents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mdi": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "remark-mdi": "workspace:*",
    "@mdi/to-html": "workspace:*",
    "@mdi/to-pdf": "workspace:*",
    "@mdi/to-epub": "workspace:*",
    "@mdi/to-docx": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
