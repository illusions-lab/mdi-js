{
  "name": "micromark-extension-mdi",
  "version": "2.0.2",
  "description": "micromark extension for MDI 2.0 (illusion Markdown) syntax",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illusions-lab/mdi-js.git",
    "directory": "packages/micromark-extension-mdi"
  },
  "homepage": "https://illusions-lab.github.io/mdi-js/",
  "bugs": "https://github.com/illusions-lab/mdi-js/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "micromark-util-types": "^2.0.0",
    "micromark-util-symbol": "^2.0.0",
    "micromark-util-character": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
