{
  "name": "@illusions-lab/mdi-to-hast",
  "version": "2.0.3",
  "description": "mdast (MDI) to hast transform, shared by the HTML/PDF/EPUB converters",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illusions-lab/mdi-js.git",
    "directory": "packages/to-hast"
  },
  "homepage": "https://illusions-lab.github.io/mdi-js/",
  "bugs": "https://github.com/illusions-lab/mdi-js/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mdi.css": "./dist/mdi.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts && cp src/mdi.css dist/mdi.css",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@illusions-lab/mdi-remark": "workspace:*",
    "mdast-util-mdi": "workspace:*",
    "mdast-util-to-hast": "^13.0.0"
  },
  "devDependencies": {
    "@types/hast": "^3.0.0",
    "@types/mdast": "^4.0.0",
    "hast-util-to-html": "^9.0.0",
    "remark-parse": "^11.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "unified": "^11.0.0",
    "vitest": "^2.1.0"
  }
}
